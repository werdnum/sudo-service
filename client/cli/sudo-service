#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any


DEFAULT_URL = "http://sudo-service.sudo-service.svc.cluster.local"
DEFAULT_TOKEN_FILE = "/var/run/secrets/sudo-service/token"
TERMINAL_PHASES = {"Executed", "Failed", "Denied", "Expired"}
NIXERY_IMAGE_PREFIX = "nixery.dev/arm64/shell"
DOCKER_NAME_MAX = 255
# Nixery package attributes become repository path components in an OCI image
# reference. Keep them within Docker's lowercase path-component grammar so an
# invalid image name cannot survive until the approved executor Job is created.
NIXERY_TOOL_RE = re.compile(r"^[a-z0-9]+(?:(?:[._]|__|[-]+)[a-z0-9]+)*$")
DEFAULT_WAIT_SECONDS = 12 * 60 * 60
REQUEST_FIELDS = {
    "reason",
    "command",
    "image",
    "profile",
    "ttlSecondsAfterApproval",
    "namespace",
    "stdin",
    "env",
    "envFrom",
    "volumes",
    "volumeMounts",
    "initContainers",
    "imagePullSecrets",
    "privileges",
}
LIST_REQUEST_FIELDS = {
    "env",
    "envFrom",
    "volumes",
    "volumeMounts",
    "initContainers",
    "imagePullSecrets",
}


class SudoServiceError(RuntimeError):
    pass


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Create a sudo-service request, wait for approval/execution, and print its output.",
        epilog=(
            "Examples:\n"
            "  sudo-service --reason 'restart stuck pod' -- kubectl delete pod foo -n bar\n"
            "  sudo-service --reason 'read one secret value' --command "
            "'kubectl get secret foo -n bar -o jsonpath={.data.password}'"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--reason", help="Reason shown to the human reviewer.")
    parser.add_argument(
        "--command",
        help=(
            "Shell command string to run. If omitted, command arguments after '--' "
            "are shell-quoted and joined."
        ),
    )
    parser.add_argument("--image", help="Optional executor image shown to the reviewer.")
    parser.add_argument(
        "--profile",
        help=(
            "Friendly server-resolved executor profile (for example kubectl or "
            "network-tools). Mutually exclusive with --image. The resolved digest "
            "is returned by the server and shown to the reviewer."
        ),
    )
    parser.add_argument(
        "--tool",
        action="append",
        default=[],
        dest="tools",
        metavar="NIX_ATTR",
        help=(
            "Top-level Nix package attribute to include in an arm64 Nixery image; "
            "repeatable. Client-side shorthand for --image; incompatible with "
            "--image, --profile, and --request-file."
        ),
    )
    parser.add_argument(
        "--retry",
        metavar="UID",
        help=(
            "Explicitly clone an Expired or Failed request owned by this requester. "
            "The new request receives fresh approval and records immutable lineage."
        ),
    )
    parser.add_argument(
        "--namespace",
        help=(
            "Namespace the executor Job runs in (default: sudo-service). Targeting "
            "another namespace lets the command mount that namespace's Secrets/PVCs "
            "as files, but the Job runs under that namespace's default ServiceAccount "
            "with no cluster-admin."
        ),
    )
    parser.add_argument(
        "--request-file",
        help=(
            "Complete HTTP request body as JSON or YAML ('-' for stdin). This may "
            "contain reason, command, and every structured request field supported "
            "by the API. It cannot be combined with request-building flags, except "
            "--stdin-file when the request body does not already set stdin."
        ),
    )
    parser.add_argument(
        "--stdin-file",
        help=(
            "File whose contents are fed to the command's stdin ('-' for this "
            "process's stdin). Avoids smuggling a multi-line payload (e.g. a manifest "
            "piped to 'kubectl apply -f -') through the command string."
        ),
    )
    parser.add_argument(
        "--preview",
        action="store_true",
        help="Print the normalized effective request as JSON to stderr before submitting.",
    )
    parser.add_argument(
        "--no-cluster-admin",
        action="store_true",
        help=(
            "Run without the cluster-admin executor ServiceAccount. Only meaningful "
            "in the default namespace; cross-namespace jobs never get cluster-admin."
        ),
    )
    parser.add_argument(
        "--image-pull-secret",
        action="append",
        default=[],
        metavar="NAME",
        dest="image_pull_secrets",
        help=(
            "Name of a registry-credential Secret (in the executor's namespace) the "
            "kubelet uses to pull a private image. Repeatable. The Secret is never "
            "exposed to the command; its name is shown to the reviewer."
        ),
    )
    parser.add_argument(
        "--ttl-seconds-after-approval",
        type=int,
        help="Seconds to retain output after approval, capped by the service.",
    )
    parser.add_argument(
        "--url",
        default=os.environ.get("SUDO_SERVICE_URL")
        or os.environ.get("K8S_AGENT_SUDO_SERVICE_URL")
        or DEFAULT_URL,
        help=f"sudo-service base URL. Default: {DEFAULT_URL}",
    )
    parser.add_argument(
        "--token-file",
        default=os.environ.get("SUDO_SERVICE_TOKEN_FILE", DEFAULT_TOKEN_FILE),
        help=f"Audience-bound service account token file. Default: {DEFAULT_TOKEN_FILE}",
    )
    parser.add_argument(
        "--poll-interval",
        type=float,
        default=5.0,
        help="Seconds between status polls. Default: 5.",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=float(DEFAULT_WAIT_SECONDS),
        help=(
            "Maximum seconds to wait before giving up locally; 0 waits indefinitely. "
            f"Default: {DEFAULT_WAIT_SECONDS} (12 hours)."
        ),
    )
    parser.add_argument(
        "--quiet",
        action="store_true",
        help="Suppress progress messages on stderr.",
    )
    parser.add_argument(
        "--detach",
        action="store_true",
        help="Submit the request, print its UID, and return without polling.",
    )
    parser.add_argument(
        "--no-validate",
        action="store_true",
        help=(
            "Skip the optional host 'sh -n' portability check. The host shell may "
            "differ from the selected executor profile; server profile-aware "
            "validation is authoritative and cannot be skipped."
        ),
    )
    parser.add_argument("argv", nargs=argparse.REMAINDER, help="Command and arguments after '--'.")
    args = parser.parse_args()
    if args.argv and args.argv[0] == "--":
        args.argv = args.argv[1:]
    if args.retry:
        conflicting = []
        for option, value in (
            ("--reason", args.reason), ("--command", args.command),
            ("command arguments after '--'", args.argv), ("--image", args.image),
            ("--profile", args.profile),
            ("--tool", args.tools),
            ("--namespace", args.namespace), ("--request-file", args.request_file),
            ("--stdin-file", args.stdin_file), ("--no-cluster-admin", args.no_cluster_admin),
            ("--image-pull-secret", args.image_pull_secrets),
            ("--ttl-seconds-after-approval", args.ttl_seconds_after_approval),
        ):
            if value is not None and value is not False and value != []:
                conflicting.append(option)
        if conflicting:
            parser.error("--retry cannot be combined with " + ", ".join(conflicting))
    elif args.request_file:
        conflicting = []
        for option, value in (
            ("--reason", args.reason),
            ("--command", args.command),
            ("command arguments after '--'", args.argv),
            ("--image", args.image),
            ("--profile", args.profile),
            ("--tool", args.tools),
            ("--namespace", args.namespace),
            ("--no-cluster-admin", args.no_cluster_admin),
            ("--image-pull-secret", args.image_pull_secrets),
            ("--ttl-seconds-after-approval", args.ttl_seconds_after_approval),
        ):
            if value is not None and value is not False and value != []:
                conflicting.append(option)
        if conflicting:
            parser.error("--request-file cannot be combined with " + ", ".join(conflicting))
    elif args.command and args.argv:
        parser.error("use either --command or arguments after '--', not both")
    elif not args.command and not args.argv:
        parser.error("provide --command or command arguments after '--'")
    if args.image and args.profile:
        parser.error("--image and --profile are mutually exclusive")
    if args.tools and (args.image or args.profile):
        parser.error("--tool cannot be combined with --image or --profile")
    if args.tools:
        invalid = sorted({
            tool for tool in args.tools
            if not NIXERY_TOOL_RE.fullmatch(tool)
        })
        if invalid:
            parser.error(
                "Nixery tool attribute(s) must be lowercase Docker path components: "
                + ", ".join(invalid)
            )
        if len(nixery_image(args.tools)) > DOCKER_NAME_MAX:
            parser.error(
                f"generated Nixery image name exceeds Docker's {DOCKER_NAME_MAX}-character limit"
            )
    if not args.retry and not args.request_file and not args.reason:
        parser.error("--reason is required unless it is provided by --request-file")
    if args.poll_interval <= 0:
        parser.error("--poll-interval must be positive")
    if args.timeout < 0:
        parser.error("--timeout must be non-negative (0 waits indefinitely)")
    if args.ttl_seconds_after_approval is not None and args.ttl_seconds_after_approval < 0:
        parser.error("--ttl-seconds-after-approval must be non-negative")
    return args


def command_from_args(args: argparse.Namespace) -> str:
    if args.command:
        return args.command
    if len(args.argv) == 1:
        return args.argv[0]
    return shlex.join(args.argv)


def nixery_image(tools: list[str]) -> str:
    """Turn repeated --tool values into the ordinary raw image API field."""
    return NIXERY_IMAGE_PREFIX + "/" + "/".join(sorted(set(tools)))


def load_request_file(path: str) -> dict[str, Any]:
    try:
        text = sys.stdin.read() if path == "-" else Path(path).read_text(encoding="utf-8")
    except OSError as exc:
        raise SudoServiceError(f"read request file {path}: {exc}") from exc
    try:
        loaded = json.loads(text)
    except json.JSONDecodeError:
        try:
            import yaml
        except ModuleNotFoundError as exc:
            raise SudoServiceError(
                "request file is not valid JSON and YAML support requires PyYAML; "
                "install it with 'python3 -m pip install -r client/cli/requirements.txt' "
                "from the checkout or 'python3 -m pip install PyYAML==6.0.3' for a "
                "standalone script"
            ) from exc
        try:
            loaded = yaml.safe_load(text)
        except yaml.YAMLError as exc:
            raise SudoServiceError(f"request file is not valid JSON or YAML: {exc}") from exc
    if not isinstance(loaded, dict):
        raise SudoServiceError("request file must contain a JSON/YAML object")
    return loaded


def find_non_string_key(value: Any, path: str = "$") -> str | None:
    if isinstance(value, dict):
        for key, nested in value.items():
            if not isinstance(key, str):
                return path
            found = find_non_string_key(nested, f"{path}.{key}")
            if found is not None:
                return found
    elif isinstance(value, list):
        for index, nested in enumerate(value):
            found = find_non_string_key(nested, f"{path}[{index}]")
            if found is not None:
                return found
    return None


def validate_request_body(body: dict[str, Any]) -> None:
    non_string_key_path = find_non_string_key(body)
    if non_string_key_path is not None:
        raise SudoServiceError(
            f"request file object keys must be strings (at {non_string_key_path})"
        )
    for field in REQUEST_FIELDS - {"reason", "command"}:
        if body.get(field, ...) is None:
            del body[field]
    unknown = sorted(set(body) - REQUEST_FIELDS)
    if unknown:
        raise SudoServiceError("unsupported request field(s): " + ", ".join(unknown))
    for field in ("reason", "command"):
        if not isinstance(body.get(field), str) or not body[field]:
            raise SudoServiceError(f"request field {field!r} must be a non-empty string")
    for field in ("image", "profile", "namespace", "stdin"):
        if field in body and not isinstance(body[field], str):
            raise SudoServiceError(f"request field {field!r} must be a string")
    if "ttlSecondsAfterApproval" in body:
        ttl = body["ttlSecondsAfterApproval"]
        if isinstance(ttl, bool) or not isinstance(ttl, int) or ttl < 0:
            raise SudoServiceError("request field 'ttlSecondsAfterApproval' must be a non-negative integer")
    for field in LIST_REQUEST_FIELDS:
        if field in body and (
            not isinstance(body[field], list) or not all(isinstance(item, dict) for item in body[field])
        ):
            raise SudoServiceError(f"request field {field!r} must be a list of objects")
    if "privileges" in body:
        privileges = body["privileges"]
        if not isinstance(privileges, dict):
            raise SudoServiceError("request field 'privileges' must be an object")
        unknown_privileges = sorted(set(privileges) - {"clusterAdmin"})
        if unknown_privileges:
            raise SudoServiceError(
                "unsupported privileges field(s): " + ", ".join(unknown_privileges)
            )
        if "clusterAdmin" in privileges and not isinstance(privileges["clusterAdmin"], bool):
            raise SudoServiceError("request field 'privileges.clusterAdmin' must be a boolean")
    try:
        json.dumps(body)
    except (TypeError, ValueError) as exc:
        raise SudoServiceError(f"request fields must contain JSON-compatible values: {exc}") from exc


def validate_command_syntax(command: str) -> str | None:
    """Optionally syntax-check with the *host's* `sh -n` before submission.

    This is a convenience portability check, not the executor's runtime shell:
    host /bin/sh may be dash while a selected profile declares busybox ash.
    Server profile-aware validation is authoritative. Return an error string on
    a host-shell parse error, or None when the check passes/cannot run.
    """
    try:
        result = subprocess.run(
            ["sh", "-n"],
            input=command,
            text=True,
            capture_output=True,
            timeout=5,
        )
    except (FileNotFoundError, OSError, subprocess.SubprocessError):
        # No usable shell to check with; defer to the server-side validation.
        return None
    if result.returncode == 0:
        return None
    detail = (result.stderr or result.stdout).strip()
    return detail or f"sh -n exited {result.returncode}"


def read_token(path: str) -> str:
    try:
        token = Path(path).read_text(encoding="utf-8").strip()
    except OSError as exc:
        raise SudoServiceError(f"read token file {path}: {exc}") from exc
    if not token:
        raise SudoServiceError(f"token file {path} is empty")
    return token


def http_json(
    url: str,
    token_file: str,
    *,
    method: str = "GET",
    body: dict[str, Any] | None = None,
    acceptable_statuses: frozenset[int] = frozenset(),
) -> dict[str, Any]:
    token = read_token(token_file)
    data = None
    headers = {"Authorization": f"Bearer {token}", "Accept": "application/json"}
    if body is not None:
        data = json.dumps(body, separators=(",", ":")).encode("utf-8")
        headers["Content-Type"] = "application/json"
    request = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(request, timeout=15) as response:
            payload = response.read()
    except urllib.error.HTTPError as exc:
        payload = exc.read()
        if exc.code not in acceptable_statuses:
            detail = payload.decode("utf-8", errors="replace").strip()
            raise SudoServiceError(f"{method} {url}: HTTP {exc.code}: {detail}") from exc
    except urllib.error.URLError as exc:
        raise SudoServiceError(f"{method} {url}: {exc.reason}") from exc
    try:
        return json.loads(payload)
    except json.JSONDecodeError as exc:
        text = payload.decode("utf-8", errors="replace")
        raise SudoServiceError(f"{method} {url}: invalid JSON response: {text}") from exc


def http_bytes(url: str, token_file: str) -> bytes:
    token = read_token(token_file)
    request = urllib.request.Request(url, headers={"Authorization": f"Bearer {token}"}, method="GET")
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            return response.read()
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace").strip()
        raise SudoServiceError(f"GET {url}: HTTP {exc.code}: {detail}") from exc
    except urllib.error.URLError as exc:
        raise SudoServiceError(f"GET {url}: {exc.reason}") from exc


def create_request(base_url: str, token_file: str, body: dict[str, Any]) -> dict[str, Any]:
    response = http_json(f"{base_url.rstrip('/')}/requests", token_file, method="POST", body=body)
    uid = str(response.get("uid") or "")
    if not uid:
        raise SudoServiceError(f"create response did not include uid: {response}")
    return response
def retry_request(base_url: str, token_file: str, uid: str) -> dict[str, Any]:
    response = http_json(
        f"{base_url.rstrip('/')}/requests/{uid}/retry", token_file,
        method="POST", body={}, acceptable_statuses=frozenset({409}),
    )
    if not response.get("uid"):
        raise SudoServiceError(f"retry response did not include uid: {response}")
    # A 409 with a UID means the server found an equivalent in-flight request.
    # Reuse it exactly like the normal create endpoint's duplicate response.
    if response.get("error"):
        response["duplicate"] = True
    return response


def get_status(base_url: str, token_file: str, uid: str) -> dict[str, Any]:
    return http_json(f"{base_url.rstrip('/')}/requests/{uid}", token_file)


def output_url(base_url: str, uid: str) -> str:
    return f"{base_url.rstrip('/')}/requests/{uid}/output"


def status_message(status: dict[str, Any]) -> str:
    phase = status.get("phase") or "Pending"
    bits = [f"phase={phase}"]
    if status.get("name"):
        bits.append(f"name={status['name']}")
    if status.get("exitCode") is not None:
        bits.append(f"exitCode={status['exitCode']}")
    return " ".join(bits)


def exit_code(status: dict[str, Any]) -> int:
    code = status.get("exitCode")
    if isinstance(code, int) and 0 <= code <= 255:
        return code or 1
    return 1


def report_output_state(status: dict[str, Any]) -> None:
    """Report output loss on stderr, keeping command stdout byte-for-byte clean."""
    capture = status.get("outputCaptureState")
    delivery = status.get("outputDeliveryState")
    if capture == "Truncated":
        total = status.get("outputTotalBytes")
        retained = status.get("outputRetainedBytes")
        detail = ""
        if isinstance(total, int) and isinstance(retained, int):
            detail = f" ({retained} of {total} bytes retained)"
        print(f"sudo-service: command output was truncated{detail}", file=sys.stderr)
    if capture == "Failed" or delivery == "Failed":
        reason = status.get("outputFailureReason")
        suffix = f": {reason}" if reason else ""
        print(f"sudo-service: command finished, but output is unavailable{suffix}", file=sys.stderr)


def main() -> int:
    args = parse_args()
    base_url = args.url.rstrip("/")

    if args.retry:
        body = {"retryOfUID": args.retry}
    elif args.request_file:
        if args.request_file == "-" and args.stdin_file == "-":
            raise SudoServiceError("--request-file - and --stdin-file - cannot both read standard input")
        body = load_request_file(args.request_file)
    else:
        body = {"reason": args.reason, "command": command_from_args(args)}
        if args.image:
            body["image"] = args.image
        elif args.tools:
            body["image"] = nixery_image(args.tools)
        if args.profile:
            body["profile"] = args.profile
        if args.ttl_seconds_after_approval is not None:
            body["ttlSecondsAfterApproval"] = args.ttl_seconds_after_approval
        if args.namespace:
            body["namespace"] = args.namespace
        if args.no_cluster_admin:
            body["privileges"] = {"clusterAdmin": False}
        if args.image_pull_secrets:
            body["imagePullSecrets"] = [{"name": name} for name in args.image_pull_secrets]

    stdin_payload: str | None = None
    if not args.retry and args.stdin_file is not None:
        if "stdin" in body:
            raise SudoServiceError("--stdin-file cannot be combined with a request file that sets stdin")
        if args.stdin_file == "-":
            stdin_payload = sys.stdin.read()
        else:
            try:
                stdin_payload = Path(args.stdin_file).read_text(encoding="utf-8")
            except OSError as exc:
                raise SudoServiceError(f"read stdin file {args.stdin_file}: {exc}") from exc
        body["stdin"] = stdin_payload

    if not args.retry:
        validate_request_body(body)
        if body.get("image") and body.get("profile"):
            raise SudoServiceError("request fields 'image' and 'profile' are mutually exclusive")

    if not args.retry and not args.no_validate:
        syntax_error = validate_command_syntax(body["command"])
        if syntax_error is not None:
            raise SudoServiceError(
                "command failed optional host syntax check (sh -n); not submitting: "
                f"{syntax_error}. The selected profile is validated by the server; "
                "use --no-validate if this is only a host/executor dialect mismatch"
            )

    if args.preview:
        print(json.dumps(body, indent=2, sort_keys=True), file=sys.stderr)

    response = retry_request(base_url, args.token_file, args.retry) if args.retry else create_request(base_url, args.token_file, body)
    uid = str(response["uid"])
    if not args.quiet:
        print(f"sudo-service request uid={uid}", file=sys.stderr)
        resolved = str(response.get("image") or "")
        profile = str(response.get("profile") or "")
        if resolved:
            prefix = f"profile={profile} " if profile else "raw image "
            print(f"executor {prefix}resolved-image={resolved}", file=sys.stderr)
    for warning in response.get("warnings") or []:
        print(f"sudo-service preflight warning: {warning}", file=sys.stderr)
    if response.get("duplicate"):
        print("sudo-service: equivalent request already exists; using its uid", file=sys.stderr)
    if args.detach:
        print(uid)
        return 0

    deadline = None if args.timeout == 0 else time.monotonic() + args.timeout
    last_phase = None
    status: dict[str, Any] = {}
    while True:
        status = get_status(base_url, args.token_file, uid)
        phase = str(status.get("phase") or "Pending")
        if phase != last_phase and not args.quiet:
            print(status_message(status), file=sys.stderr)
            last_phase = phase
        if phase in TERMINAL_PHASES:
            break
        if deadline is not None and time.monotonic() >= deadline:
            raise SudoServiceError(f"timed out waiting for request {uid} after {args.timeout:g}s")
        sleep_seconds = args.poll_interval
        if deadline is not None:
            sleep_seconds = min(sleep_seconds, max(0.1, deadline - time.monotonic()))
        time.sleep(sleep_seconds)

    phase = str(status.get("phase") or "")
    if phase in {"Executed", "Failed"}:
        report_output_state(status)
        if status.get("outputSecretRef"):
            sys.stdout.buffer.write(http_bytes(output_url(base_url, uid), args.token_file))
            sys.stdout.buffer.flush()
        elif (
            phase == "Failed"
            and status.get("exitCode") is None
            and status.get("outputCaptureState") != "Failed"
            and status.get("outputDeliveryState") != "Failed"
        ):
            # No output to return: the controller's failureReason is the only
            # explanation, so surface it like Denied/Expired do — even under
            # --quiet, which suppresses progress, not the terminal error reason.
            reason = status.get("failureReason")
            if reason:
                print(f"sudo-service request failed before output was available: {reason}", file=sys.stderr)
            else:
                print("sudo-service request failed before output was available", file=sys.stderr)
        return 0 if phase == "Executed" else exit_code(status)

    if phase == "Denied":
        reason = status.get("denialReason") or "no denial reason provided"
        raise SudoServiceError(f"request {uid} denied: {reason}")
    if phase == "Expired":
        raise SudoServiceError(f"request {uid} expired before approval")
    raise SudoServiceError(f"request {uid} reached unexpected phase {phase!r}")


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("interrupted", file=sys.stderr)
        raise SystemExit(130)
    except SudoServiceError as exc:
        print(f"sudo-service: {exc}", file=sys.stderr)
        raise SystemExit(1)
